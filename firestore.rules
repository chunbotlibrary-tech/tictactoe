rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rooms collection
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(roomId) &&
        incoming().players.X == request.auth.uid &&
        incoming().status == 'waiting' &&
        incoming().board.size() == 225; // 15x15

      allow update: if isSignedIn() && (
        // Join room
        (existing().status == 'waiting' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['players', 'status', 'lastMoveAt']) &&
         incoming().players.O == request.auth.uid &&
         incoming().status == 'active') ||
        
        // Make move
        (existing().status == 'active' &&
         (existing().players.X == request.auth.uid || existing().players.O == request.auth.uid) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['board', 'turn', 'status', 'winner', 'scores', 'lastMoveAt'])) ||
         
        // Reset game
        ((existing().players.X == request.auth.uid || existing().players.O == request.auth.uid) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['board', 'turn', 'status', 'winner', 'lastMoveAt']))
      );

      // Chat sub-collection
      match /chats/{chatId} {
        allow list: if isSignedIn();
        allow create: if isSignedIn() && 
          incoming().sender in ['X', 'O'] &&
          incoming().text is string && incoming().text.size() < 500;
        allow delete: if isSignedIn(); // Allow cleanup (auto-delete)
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
